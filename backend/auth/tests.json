{
  "tests": [
    {
      "name": "Get me unauthorized",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "List users unauthorized",
      "method": "POST",
      "path": "/",
      "body": {"action": "list_users"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Set role unauthorized",
      "method": "POST",
      "path": "/",
      "body": {"action": "set_role", "user_id": 1, "role": "staff"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Forgot password no email",
      "method": "POST",
      "path": "/",
      "body": {"action": "forgot_password"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Reset password short",
      "method": "POST",
      "path": "/",
      "body": {"action": "reset_password", "email": "a@b.ru", "code": "123456", "password": "123"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Create client unauthorized",
      "method": "POST",
      "path": "/",
      "body": {"action": "create_client", "email": "new@client.ru"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}